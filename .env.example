# Copia este archivo a .env y completa tus credenciales

# Opción 1: Conexión Pro (si tienes ArcGIS Pro abierto y conectado, no necesitas .env)
#           El usuario YA debe estar autenticado en Pro.

# Opción 2: OAuth2 - Abre el navegador para que el usuario se autentique
# ARCGIS_USE_OAUTH=true
# ARCGIS_URL=https://www.arcgis.com  # O tu portal Enterprise (opcional, default: ArcGIS Online)
# ARCGIS_CLIENT_ID=tu_client_id      # Opcional, usa 'arcgisonline' por defecto

# Opción 3: Perfil nombrado (recomendado para desarrollo)
# ARCGIS_PROFILE=mi_perfil

# Opción 4: API Key (Enterprise 11.4+ o AGOL)
# ARCGIS_URL=https://mi-portal.com/portal
# ARCGIS_API_KEY=tu_api_key_aqui

# Opción 5: Token temporal
# ARCGIS_URL=https://mi-portal.com/portal
# ARCGIS_TOKEN=tu_token_aqui

# Opción 6: Usuario/Contraseña
# ARCGIS_URL=https://mi-portal.com/portal
# ARCGIS_USER=mi_usuario
# ARCGIS_PASS=mi_contraseña

# Guardarrailes (opcional)
# ARCGIS_WRITE_ENABLED=false  # Cambiar a true para permitir operaciones de escritura
